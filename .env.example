# Solana RPC endpoint (use a private node or Helius/QuickNode for reliability)
RPC_URL=https://api.mainnet-beta.solana.com

# Path to the bot wallet keypair JSON generated by: npm run create-wallet
WALLET_PATH=keys/bot-wallet.json

# Wrapped SOL mint (fixed on Solana mainnet)
SOL_MINT=So11111111111111111111111111111111111111112

# USDT.z mint address on Solana mainnet
USDTZ_MINT=<paste USDT.z mint address here>

# SOL amount to use per trade entry (e.g. 0.01 = 0.01 SOL)
ENTRY_SOL=0.01

# Take-profit threshold in percent (e.g. 1.5 = exit when +1.5% above entry)
TAKE_PROFIT_PCT=1.5

# Stop-loss threshold in percent (negative, e.g. -0.5 = exit when -0.5% below entry)
STOP_LOSS_PCT=-0.5

# Slippage tolerance in basis points (100 = 1%)
SLIPPAGE_BPS=100

# Set to 1 to simulate trades without submitting transactions
DRY_RUN=1

# Polling interval in milliseconds between price checks
POLL_MS=5000
